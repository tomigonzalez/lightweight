// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
model User {
  id        String     @id @default(cuid())
  email     String     @unique
  routines  Routine[]
  workouts  Workout[]
  exercises Exercise[]
  
  activePlanId String? // <-- Opcional: para saber qué "Semana" está usando
}

model Routine {
  id        String            @id @default(cuid())
  name      String            // Ej: "Push Day"
  dayOfWeek Int?              // <-- 0=Domingo, 1=Lunes... Para el Dashboard automático
  userId    String
  user      User              @relation(fields: [userId], references: [id])
  exercises RoutineExercise[]
  workouts  Workout[]        
}

model Exercise {
  id          String            @id @default(cuid())
  name        String            
  muscleGroup String
  isCustom    Boolean           @default(false) 
  userId      String?           
  user        User?             @relation(fields: [userId], references: [id])
  routines    RoutineExercise[]
  sets        Set[]
}

model RoutineExercise {
  id         String   @id @default(cuid())
  routineId  String
  exerciseId String
  routine    Routine  @relation(fields: [routineId], references: [id])
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  order      Int?     
  
}

model Workout {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  routineId String?  // <-- Para saber que este entrenamiento fue el "Push Day"
  routine   Routine? @relation(fields: [routineId], references: [id])
  sets      Set[]
}

model Set {
  id         String   @id @default(cuid())
  weight     Float
  reps       Int
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  workoutId  String
  workout    Workout  @relation(fields: [workoutId], references: [id])
  createdAt  DateTime @default(now()) 
}